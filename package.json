{
  "name": "loopride",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proappstore-online/loopride.git"
  },
  "scripts": {
    "dev": "pnpm --filter @loopride/web dev",
    "build": "pnpm --filter @loopride/web build",
    "preview": "pnpm --filter @loopride/web preview",
    "typecheck": "pnpm --filter @loopride/web exec tsc -b",
    "test": "pnpm --filter @loopride/web test",
    "test:watch": "pnpm --filter @loopride/web test:watch",
    "test:coverage": "pnpm --filter @loopride/web test:coverage",
    "test:e2e": "pnpm --filter @loopride/web test:e2e",
    "lint": "pnpm --filter @loopride/web lint"
  },
  "devDependencies": {
    "vite-plugin-pwa": "^1.3.0"
  }
}